# -----------------------------------------------------------------------------
# PITCHPILOT AI - FRONTEND PRODUCTION ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# Instructions:
# 1. Copy this file to `.env.production` (or inject these into your host, e.g. Vercel).
# 2. DO NOT commit `.env.production` to version control.
# 3. These variables are PUBLIC and exposed to the browser. Do not put secret keys here.

# Backend API URL (Use https:// for production)
VITE_API_URL=https://your-production-backend-url.onrender.com

# Backend WebSocket URL (Use wss:// for production, matches VITE_API_URL domain)
VITE_WS_URL=wss://your-production-backend-url.onrender.com/ws/realtime

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
