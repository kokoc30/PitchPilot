API_ENV=development
FRONTEND_URL=http://localhost:5473
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required by Task 14 backend session persistence. Never expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
JWT_SECRET=dev-placeholder-change-me
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# LLM orchestration (Task 11)
# Values: auto | mock | openai | gemini
# auto -> OpenAI if OPENAI_API_KEY exists, else Gemini if GEMINI_API_KEY exists, else mock
LLM_PROVIDER=auto
LLM_TIMEOUT_SECONDS=20
LLM_FALLBACK_TO_MOCK=true

# Transcription (Task 7)
# Leave DEEPGRAM_API_KEY blank to run in mock/demo mode automatically.
# Get a free API key at https://deepgram.com
DEEPGRAM_API_KEY=
# Values: auto | deepgram | mock
# auto  → use Deepgram if DEEPGRAM_API_KEY is set, otherwise mock
# deepgram → require Deepgram key (error if missing)
# mock  → always use local demo provider (no external API)
TRANSCRIPTION_PROVIDER=auto

# Resume RAG foundation (Task RAG-1)
# Embeddings lazy-load on first resume upload; first run may download the model.
RESUME_RAG_ENABLED=true
RESUME_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RESUME_EMBEDDING_DIMENSION=384
RESUME_MAX_FILE_MB=5
RESUME_CHUNK_SIZE_CHARS=900
RESUME_CHUNK_OVERLAP_CHARS=150
