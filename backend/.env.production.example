# -----------------------------------------------------------------------------
# PITCHPILOT AI - BACKEND PRODUCTION ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# Instructions:
# 1. Provide these variables in your hosting provider's Secret Manager (e.g. Render, Railway).
# 2. DO NOT commit actual secrets to version control.
# 3. SUPABASE_SERVICE_ROLE_KEY is STRICTLY required to be backend-only. DO NOT leak to frontend.

# API Configuration
API_ENV=production
FRONTEND_URL=https://your-frontend-url.vercel.app
BACKEND_PUBLIC_URL=https://your-backend-url.onrender.com
# EXTRA_CORS_ORIGINS=https://another-allowed-domain.com,https://test.app

# Supabase Auth & Persistence (Required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# LLM Providers (Optional - at least one recommended if not using mock)
# OPENAI_API_KEY=sk-proj-...
# GEMINI_API_KEY=AIza...

# Transcription Provider (Optional - recommended for live transcription)
# DEEPGRAM_API_KEY=your-deepgram-key

# Provider Overrides (auto | mock | deepgram | openai | gemini)
# TRANSCRIPTION_PROVIDER=auto
# LLM_PROVIDER=auto
# LLM_FALLBACK_TO_MOCK=true

# Resume RAG foundation
RESUME_RAG_ENABLED=true
RESUME_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RESUME_EMBEDDING_DIMENSION=384
RESUME_MAX_FILE_MB=5
RESUME_CHUNK_SIZE_CHARS=900
RESUME_CHUNK_OVERLAP_CHARS=150
